generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  role         UserRole  @default(USER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  devices      Device[]
}

model Device {
  id              String        @id @default(uuid())
  ownerId         String?
  owner           User?         @relation(fields: [ownerId], references: [id])

  name            String?
  fcmToken        String?
  secretHash      String?

  publicIp        String?
  lanIp           String?
  proxyUsername   String?
  proxyPassword   String?

  lastSeenAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  status          DeviceStatus?
  commands        Command[]
}

model DeviceStatus {
  deviceId        String   @id
  device          Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  socksRunning    Boolean  @default(false)
  socksPort       Int      @default(1080)
  credsConfigured Boolean  @default(false)

  updatedAt       DateTime @updatedAt
}

model Command {
  id         String   @id @default(uuid())
  deviceId   String
  device     Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  type       String
  payload    Json?
  status     String   @default("sent")

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([deviceId, createdAt])
}

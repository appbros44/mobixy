# Backend HTTP/WS port
PORT=8787

# Enable DB persistence (PostgreSQL via Prisma)
# Set to true after you have Postgres running + migrations applied
USE_DB=false

# Prisma Postgres connection string
DATABASE_URL=postgresql://mobixy:mobixy@localhost:5432/mobixy?schema=public

# Firebase Admin SDK service account JSON path (for FCM wake)
# Keep this file out of git; provide an absolute path or a mounted secret path in production
FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/path/to/service-account.json

# Device enrollment token (device must present this when opening WS)
ENROLL_TOKEN=dev-enroll-token

# Admin bootstrap (DB-backed) - created on startup if missing
ADMIN_EMAIL=admin@mobixy.local
ADMIN_PASSWORD=admin

# JWT signing secret for admin auth (change in production)
JWT_SECRET=dev-jwt-secret

# JWT expiry (jsonwebtoken format)
JWT_EXPIRES_IN=7d

# Device JWT expiry (jsonwebtoken format)
DEVICE_JWT_EXPIRES_IN=30d

# Vite dev server origin for the admin panel
UI_ORIGIN=http://localhost:5173
